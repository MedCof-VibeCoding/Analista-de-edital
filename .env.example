# Provider padrão quando a UI não enviar nenhum: openai | gemini | deepseek
AI_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# DeepSeek (API OpenAI-compatível)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# App
MAX_PDF_MB=20
OUTPUTS_DIR=./outputs

# MongoDB
# Prefira a connection string PADRÃO (mongodb://) em vez da SRV (mongodb+srv://),
# pois redes que não resolvem registros DNS SRV causam o erro "querySrv ECONNREFUSED".
# Ex.: mongodb://user:pass@host-00:27017,host-01:27017,host-02:27017/?ssl=true&replicaSet=...&authSource=admin&retryWrites=true&w=majority
MONGODB_URI=
MONGODB_DB=analista_editais
MONGODB_COLLECTION=analyses

# Auth (V1: credenciais fixas, sem banco)
AUTH_USERNAME=admin
AUTH_PASSWORD=Blogbonito123
AUTH_SESSION_SECRET=please-change-me-in-production
